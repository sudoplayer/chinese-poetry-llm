# ============================================
# Chinese Poetry LLM — 环境变量配置
# 复制此文件为 .env，按需修改
# cp .env.example .env
# ============================================

# DeepSeek API 密钥（必需）—— 用于诗词评分 & 生成
DEEPSEEK_API_KEY=sk-your-key-here

# DeepSeek 模型名
# DEEPSEEK_MODEL=deepseek-v4-flash

# Hugging Face 令牌（可选）—— 部分模型需登录下载
# HUGGINGFACE_API_KEY=hf_your_token_here

# 分布式训练（多卡时用）
# LOCAL_RANK=0
